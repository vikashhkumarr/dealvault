{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/browse", "destination": "/browse.html" },
    { "source": "/submit", "destination": "/submit.html" },
    { "source": "/deal/:slug", "destination": "/deal.html" },
    { "source": "/category/:name", "destination": "/browse.html" },
    { "source": "/brand/:name", "destination": "/browse.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
